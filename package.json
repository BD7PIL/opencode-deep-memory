{
  "name": "@bd7pil/opencode-deep-memory",
  "version": "0.10.1",
  "description": "Persistent context intelligence for OpenCode — cross-session memory, compaction checkpoints, context reconstruction.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BD7PIL/opencode-deep-memory.git"
  },
  "files": [
    "dist",
    ".opencode",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "memory",
    "context",
    "bm25",
    "fts",
    "plugin",
    "persistent-memory"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*",
    "@opencode-ai/sdk": "*",
    "@types/node": "^20.11.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
